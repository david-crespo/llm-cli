    "ansis": "npm:ansis@^4.2.0",
    "markdown-exit": "npm:markdown-exit@^1.0.0-beta.9",
    "markdown-table": "https://esm.sh/markdown-table@3.0.4",
    "openai": "npm:openai@6.34.0",
